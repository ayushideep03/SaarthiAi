# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database Settings
# Replace user, password, dbname with your local postgres setup
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/saarthi_db

# Gemini API Settings
GEMINI_API_KEY=your_gemini_api_key_here

# WhatsApp Cloud API Settings
WHATSAPP_TOKEN=your_whatsapp_cloud_api_token_here
WHATSAPP_VERIFY_TOKEN=your_whatsapp_webhook_verify_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here

# Bhashini API Settings
BHASHINI_USER_ID=your_bhashini_user_id
BHASHINI_API_KEY=your_bhashini_api_key
BHASHINI_PIPELINE_ID=your_bhashini_pipeline_id
